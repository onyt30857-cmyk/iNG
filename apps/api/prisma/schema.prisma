// 练爱 - 数据库 Schema (Prisma)
// 
// 用法:
// 1. 把这份文件复制到 apps/api/prisma/schema.prisma
// 2. 创建 PostgreSQL 数据库,启用 pgvector 扩展
// 3. 配置 DATABASE_URL 环境变量
// 4. 跑 `pnpm prisma migrate dev --name init`
//
// 重要约束(见 CLAUDE.md):
// - 所有涉及关系数据的表都有 relationship_id (除 users 自己)
// - 软删除字段 deleted_at,30 天后由 worker 真删
// - 所有时间字段用 timestamptz
// - 所有 ID 用 cuid 或 uuid

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // Railway 用 alpine linux + openssl 3,prisma 默认只生成 native 引擎
  // 没这条会 "Could not locate the binary engine" 启动失败
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// 用户相关
// ============================================================

model User {
  id String @id @default(cuid())

  // 微信登录信息(spec-002 微信扫码,改 optional 让匿名账户也能存在)
  wechat_open_id  String? @unique
  wechat_union_id String? @unique

  // 匿名账户备份码 hash(bcrypt) — 用户在新设备输 backup_code 凭这个恢复账户
  // 不存明文,不可追溯到原码
  backup_code_hash String? @db.Text

  // 用户填写信息
  nickname   String?
  avatar_url String?
  gender     Gender?
  birth_year Int?
  city       String?

  // === Admin 内部字段(用户不可见,只在 admin 后台展示)===
  // spec-014 用户颗粒度管理:运营给用户起的别名 / 简称,用于列表快速识别
  // 例:"老王-创始人朋友" / "张总-投资人内测" / "客服 case#42"
  // 列表搜索能命中,跟 nickname 一起展示
  admin_alias String? @db.VarChar(100)

  // 产品状态
  usage_stage    UsageStage @default(NEWBIE)
  total_sessions Int        @default(0)

  // Phase 1 P1.2(2026-05-14)— 购买积分余额(不重置,只增减)
  // 免费(DailyUsage)用完后才动这层;支付完成 grant + 消耗 consume 全经 CreditTransaction
  purchased_points Int @default(0)

  // Onboarding(spec-018):
  // null = 还没走完 Welcome→填昵称头像 流程,前端检测到要跳转 onboarding 页
  // 有值 = 已经走完,直接进主页
  onboarding_completed_at DateTime? @db.Timestamptz

  // 用户语气指纹(JSON 存储)
  // 详见 user-language-fingerprint 表

  // 时间
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  // 关系
  relationships        Relationship[]
  sessions             Session[]
  language_fingerprint UserLanguageFingerprint?
  patterns             UserPattern[]
  growth_reports       GrowthReport[]
  subscriptions        Subscription[]
  payments             Payment[]
  data_deletions       DataDeletionLog[]
  // M3+ FEEDBACK
  product_feedback     ProductFeedback[]
  feedback_triggers    FeedbackTriggerLog[]
  // Phase 1 P1.1(2026-05-14)— 4 类新场景
  tree_hole_sessions   TreeHoleSession[]
  interpret_sessions   InterpretSession[]
  archive_reports      ArchiveReport[]
  deep_reports         DeepReport[]
  // Phase 1 P1.2(2026-05-14)— 积分流水
  credit_transactions  CreditTransaction[]

  @@index([deleted_at])
  @@map("users")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// 使用阶段:决定 AI 介入程度
enum UsageStage {
  NEWBIE // 新手:前 30 天/30 次
  FAMILIAR // 熟悉:30-90 天/30-90 次
  ADVANCED // 进阶:90 天+
}

// 用户语气指纹(独立表方便累积更新)
model UserLanguageFingerprint {
  id      String @id @default(cuid())
  user_id String @unique

  // 用户的字词偏好(JSON 数组)
  // 例: ["哈哈", "嗯", "好的", "哎呀"]
  preferred_phrases String[]

  // 标点习惯
  uses_emoji     Boolean @default(false)
  uses_period    Boolean @default(true) // 是否爱用句号
  message_length String  @default("medium") // short / medium / long

  // 语气强度 0-100
  formality    Int @default(50) // 越高越正式
  emotionality Int @default(50) // 越高越情绪化

  // 累积样本数
  sample_count Int @default(0)

  // 实际样本(用于 few-shot)
  // 存最近 30 条用户的真实输出
  recent_samples Json @default("[]")

  updated_at DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_language_fingerprints")
}

// 用户行为模式(由 Pattern Detector 异步生成)
model UserPattern {
  id      String @id @default(cuid())
  user_id String

  pattern_type String // 例: "灾难化思维" / "安全行为" / "羞耻陈述"
  description  String // 具体描述

  // 出处:这个模式从哪几个 session 提取的
  source_sessions String[] // session_id 数组

  occurrences   Int      @default(1)
  first_seen_at DateTime @db.Timestamptz
  last_seen_at  DateTime @db.Timestamptz

  // 用户是否已经看到这条模式(在月度报告中)
  surfaced Boolean @default(false)

  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, deleted_at])
  @@map("user_patterns")
}

// ============================================================
// 关系相关
// ============================================================

model Relationship {
  id      String @id @default(cuid())
  user_id String

  // 用户给这段关系起的名字
  name String // 例: "小雨"

  // 头像(渐变色 hash 或上传 URL)
  avatar_seed String?
  avatar_url  String?

  // 关系阶段(用户填,产品识别)
  stage RelationshipStage @default(INIT)

  // Phase 1 P1.1(2026-05-14)— 关系类型(Round 1.3 漏洞修复)
  // P1.5 WORK 类型不生成 observation/assertion(隐私合规)
  type RelationshipType @default(ROMANTIC)

  // 用户填写的基础事实(JSON)
  // 例: { how_met: "朋友介绍", first_met_at: "2024-03", key_facts: ["喜欢爵士乐"] }
  basic_facts Json @default("{}")

  // 用户提醒老 K 的注意事项(JSON 数组)
  user_reminders Json @default("[]")

  // 是否归档
  archived Boolean @default(false)

  // 时间
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  // 关系
  user               User                      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sessions           Session[]
  observations       RelationshipObservation[]
  assertions         ProfileAssertion[]
  interpret_sessions InterpretSession[]
  archive_reports    ArchiveReport[]
  deep_reports       DeepReport[]

  @@index([user_id, archived, deleted_at])
  @@map("relationships")
}

enum RelationshipStage {
  INIT // 初识
  FLIRTING // 暧昧
  COMMITTED // 在一起
  CONFLICT // 冲突中
  RECOVERY // 挽回中
  ENDED // 已结束
}

// Phase 1 P1.1(2026-05-14)— 关系类型 enum
enum RelationshipType {
  ROMANTIC // 恋爱 / 暧昧 / 前任(默认)
  FAMILY // 家人
  WORK // 工作(P1.5 不生成 observation/assertion)
  FRIEND // 朋友
  OTHER // 其他 / 未分类
}

// Phase 1 P1.1(2026-05-14)— 4 类对话/工具场景
enum ChatType {
  CHAT // 老白陪练(关联具体 relationship,主对话流)
  TREE_HOLE // 老白树洞(无 relationship)
  INTERPRET // 解读神器(可选 relationship)
  ICEBREAKER // 破冰生成器(Phase 2 实施,enum 先加)
}

// Phase 1 P1.1(2026-05-14)— 树洞专用 message role(不复用主 MessageRole 避免污染)
enum TreeHoleMessageRole {
  USER
  LAOKE
}

// 关系观察:每条带 source 追溯
// 这是数据壁垒的核心
model RelationshipObservation {
  id              String @id @default(cuid())
  relationship_id String // ★ 强制约束

  observation_text String @db.Text

  // 出处
  source_session_id  String?
  source_message_ids String[] // message_id 数组

  // 类型:对方的事实 / 用户的反思 / 关系动态等
  observation_type String

  // 置信度 0-1 (Profile Updater 提取时的置信度)
  confidence Float @default(0.5)

  // 是否被用户标记"这条不准"
  user_disputed     Boolean @default(false)
  user_dispute_note String?

  // 是否提升到 profile_assertions
  promoted Boolean @default(false)

  // 向量化(M2 启用)
  // embedding         Unsupported("vector(1536)")?

  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)

  @@index([relationship_id, deleted_at])
  @@index([source_session_id])
  @@map("relationship_observations")
}

// 高频核心断言:从多次 observation 凝练出来
// Prompt 组装时优先注入这一层
model ProfileAssertion {
  id              String @id @default(cuid())
  relationship_id String // ★ 强制约束

  assertion_text String @db.Text // 例: "她不喜欢被催"

  // 这个断言基于哪几个 observation
  source_observation_ids String[]

  // 置信度(由多个 observation 累积)
  confidence Float

  // 用户是否标记不准
  user_disputed Boolean @default(false)

  // 优先级(决定 prompt 中的顺序)
  priority Int @default(50)

  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)

  @@index([relationship_id, deleted_at, priority])
  @@map("profile_assertions")
}

// ============================================================
// 复盘会话相关
// ============================================================

// Session 表:spec-006 之后 Session 仍用作"对话线程"容器(messages 通过 session_id 关联),
// 但下面以 // @deprecated 标注的 6 个字段是 spec-005 6 状态机时代的产物,
// spec-006 路径下永远停在默认值不更新。M3.0 Step 5 标 @deprecated 但不删 column,M4 决定物理删。
model Session {
  id              String @id @default(cuid())
  user_id         String
  relationship_id String // ★ 强制约束

  /// @deprecated spec-005 6 状态机字段 — spec-006 路径下永远 ENTRY 不变
  state SessionState @default(ENTRY)

  /// @deprecated spec-005 PARSING 阶段产物 — spec-006 路径下永远 null
  scenario Json?

  /// @deprecated spec-005 ENTRY 阶段产物 — spec-006 路径下永远 null
  entry_note String?

  /// @deprecated spec-005 XState context 快照 — spec-006 路径下永远 "{}"
  state_context Json @default("{}")

  /// @deprecated spec-005 危机干预标记 — spec-006 走红线另一套机制(red-line-guard)
  crisis_triggered Boolean @default(false)

  /// @deprecated spec-005 红线标记 — 同上,spec-006 不写
  red_line_triggered Boolean @default(false)

  // 时间
  started_at DateTime  @default(now()) @db.Timestamptz
  closed_at  DateTime? @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  // 关系
  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  relationship      Relationship     @relation(fields: [relationship_id], references: [id], onDelete: Cascade)
  messages          Message[]
  reflections       UserReflection[]
  generated_replies GeneratedReply[]

  @@index([user_id, closed_at])
  @@index([relationship_id, closed_at])
  @@map("sessions")
}

enum SessionState {
  ENTRY
  PARSING
  REFLECTING
  DIAGNOSING
  PLANNING
  DRAFTING
  CLOSED
}

// 消息(对话内容)
model Message {
  id              String @id @default(cuid())
  session_id      String
  relationship_id String // ★ 冗余存储,方便审计和过滤

  // 角色
  role MessageRole

  // 内容(用户消息可能是文本或截图)
  content String? @db.Text

  // 截图相关(role = USER_SCREENSHOT 时使用)
  screenshot_url String?
  ocr_result     Json? // OCR 识别后的结构化数据

  // AI 调用相关(role = LAOKE 时使用)
  model             String? // "claude-sonnet-4" / "gemini-2.5-flash"
  prompt_tokens     Int?
  completion_tokens Int?
  cost_usd          Float?

  // 是否是流式输出(还在生成中?)
  is_streaming Boolean @default(false)

  // 时间
  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id, created_at])
  @@index([relationship_id])
  @@map("messages")
}

enum MessageRole {
  USER // 用户文字输入
  USER_SCREENSHOT // 用户上传截图
  LAOKE // 老 K 输出
  SYSTEM // 系统消息(状态切换提示等)
}

// @deprecated spec-005 REFLECTING 阶段产物。spec-006 不再写,只在 account-deletion +
// relationship.service 用作历史数据清理。M4 决定是否物理删表。
model UserReflection {
  id         String @id @default(cuid())
  session_id String

  question       String // 老 K 问的问题
  question_index Int // 第几个问题(1-3)

  user_answer String @db.Text

  // 是否被老 K 追问过
  follow_up Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("user_reflections")
}

// @deprecated spec-005 DRAFTING 阶段产物。spec-006 已不创建,代码 0 引用。
// 表保留是为旧数据查得到。M4 决定是否物理删表。
model GeneratedReply {
  id         String @id @default(cuid())
  session_id String

  // 第几张卡片(0/1/2)
  card_index Int

  // 卡片方向标签(例: "轻巧化解" / "换话题" / "温柔回应")
  direction_label String

  // 话术内容
  reply_text String @db.Text

  // 三个解释
  what_it_does String // 做了什么
  good_for     String // 适合什么
  trade_off    String // 代价是什么

  // 用户是否选了这张卡
  user_selected Boolean @default(false)

  // 用户是否调过(自然语言追问打磨)
  user_refined Boolean @default(false)
  refined_text String? @db.Text

  // 用户是否复制了
  user_copied Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz

  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("generated_replies")
}

// ============================================================
// 成长报告
// ============================================================

model GrowthReport {
  id      String @id @default(cuid())
  user_id String

  // 报告类型和时间范围
  report_type  ReportType
  period_start DateTime   @db.Date
  period_end   DateTime   @db.Date

  // 数据统计
  total_sessions      Int
  total_relationships Int

  // AI 生成的内容
  // 例: { "三件事": [...], "关键瞬间": [...], "下个月建议": "..." }
  content Json

  // 用户是否查看过
  read_at DateTime? @db.Timestamptz

  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, period_end])
  @@map("growth_reports")
}

enum ReportType {
  MONTHLY
  QUARTERLY // M2
  YEARLY // M3
}

// ============================================================
// 付费相关
// ============================================================

model Subscription {
  id      String @id @default(cuid())
  user_id String

  plan   SubscriptionPlan
  status SubscriptionStatus

  // 起止时间
  started_at DateTime @db.Timestamptz
  expires_at DateTime @db.Timestamptz

  // 平台和支付信息
  platform                      PaymentPlatform
  apple_transaction_id          String?         @unique
  apple_original_transaction_id String?
  wechat_transaction_id         String?         @unique

  // 自动续费
  auto_renew Boolean @default(true)

  // 取消信息
  canceled_at   DateTime? @db.Timestamptz
  cancel_reason String?

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  SINGLE // 单次 ¥6.6
  MONTHLY // 月付 ¥39
  YEARLY // 年付 ¥299
}

// 付费墙 v0 — 每日免费额度跟踪
// CLAUDE.md §11 不变式 #5:付费墙温和,免费层至少能完整体验。
// 用 (user_id, day) 唯一,每天一行,各 counter 累加。
model DailyUsage {
  id      String @id @default(cuid())
  user_id String
  day     String // "YYYY-MM-DD"

  turn_count  Int @default(0) // conversation-turn 调用次数
  ocr_count   Int @default(0) // OCR 截图分析次数
  heavy_count Int @default(0) // extract / generate-insights / summarize 等重操作

  // spec-019:积分系统(单一货币替代 turn/ocr/heavy 三种独立上限)
  // 1 turn = 5 / 1 ocr = 20 / 1 heavy = 30(POINTS_PER_ACTION 在 service 里)
  // 主约束:points_used >= daily_free_points → 拒绝(订阅 bypass)
  // 旧三个 counter 保留(运营审计 / 行为分析用),不再做硬上限
  points_used Int @default(0)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, day])
  @@index([user_id])
  @@map("daily_usage")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  REFUNDED
  PENDING_REFUND
}

enum PaymentPlatform {
  APPLE_IAP
  WECHAT_PAY
}

// 单笔支付记录
model Payment {
  id              String  @id @default(cuid())
  user_id         String
  subscription_id String?

  amount   Decimal @db.Decimal(10, 2) // 金额(元)
  currency String  @default("CNY")

  platform PaymentPlatform

  // 平台 transaction id
  platform_transaction_id String? @unique

  status PaymentStatus

  // 退款相关
  refunded_at   DateTime? @db.Timestamptz
  refund_amount Decimal?  @db.Decimal(10, 2)
  refund_reason String?

  // 原始 webhook 数据(用于审计)
  raw_data Json?

  // Phase 1 P1.3(2026-05-14)— 商品 DB 化 + 微信下单
  product_type     ProductType?
  credit_pack_size Int?
  out_trade_no     String?      @unique // 我方生成的订单号
  wechat_prepay_id String?              // 微信 JSAPI 下单返回

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user           User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  refund_tickets RefundTicket[]

  @@index([user_id])
  @@index([platform_transaction_id])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

// ============================================================
// 数据控制权
// ============================================================

model DataDeletionLog {
  id      String @id @default(cuid())
  user_id String

  type      DeletionType
  target_id String? // relationship_id / session_id / observation_id

  // 30 天反悔窗口
  requested_at DateTime  @default(now()) @db.Timestamptz
  execute_at   DateTime  @db.Timestamptz
  executed     Boolean   @default(false)
  executed_at  DateTime? @db.Timestamptz

  // 用户撤销(在 execute_at 前)
  canceled_at   DateTime? @db.Timestamptz
  cancel_reason String?

  created_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([execute_at, executed])
  @@map("data_deletion_logs")
}

enum DeletionType {
  ACCOUNT_DELETE // 注销账号
  RELATIONSHIP_DELETE // 删除整段关系
  SESSION_DELETE // 删除单次复盘
  OBSERVATION_DELETE // 删除单条观察
}

// ============================================================
// 内容审核日志
// ============================================================

model ModerationLog {
  id String @id @default(cuid())

  // 触发的来源
  source_type String // "user_input" / "ai_output"
  source_id   String? // message_id 等
  user_id     String?

  // 内容
  content String @db.Text

  // 审核结果
  service      String // "aliyun_content_security" / "internal_red_line"
  passed       Boolean
  category     String? // "porn" / "politics" / "violence" / "self_harm" 等
  confidence   Float?
  raw_response Json?

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([user_id, created_at])
  @@index([passed, category])
  @@map("moderation_logs")
}

// ============================================================
// Prompt 评估反馈(用于持续优化)
// ============================================================

// 红线规则(spec-026)— 完全自定义,运营可改/禁用/新增/删除
// 设计:服务启动时全量加载到内存 cache,guard.ts 从 cache 读;改了 invalidate
// 默认 seed 9 条(SEXUAL_PURPOSE/PUA/NSFW/STALKING/DECEPTION/MINOR/NON_CONSENT/SELF_HARM/VIOLENCE)
//
// keyword_patterns:JSON 数组,每条是 regex source 字符串(不含两端 //)
//   运行时 new RegExp(source, 'i') 转回正则;不合法的会被 service 校验拦下
model RedLineRule {
  id String @id @default(cuid())

  // 唯一标识(UPPER_SNAKE),如 SEXUAL_PURPOSE。新增时必填,改不了
  category String @unique

  // 中文名,如 "性目的话术"
  name String @db.VarChar(100)

  // 运营后台看的描述
  description String @db.Text

  // 关键词 regex(JSON 数组,每条是 regex source 字符串)
  // 例:["约炮", "一夜情", "找[人个]?睡"]
  keyword_patterns Json @default("[]")

  // 触发后的拒绝文案(老白回给用户的话)
  refusal_reply String @db.Text

  // Phase 1 P1.5(2026-05-14)— 树洞场景专用关怀文案
  // ctx.scene='tree_hole' 时优先用此版;null fallback 到 refusal_reply
  refusal_reply_tree_hole String? @db.Text

  // 是否启用(false 时跳过这条规则的检测)
  enabled Boolean @default(true)

  // 排序权重(列表展示用,越小越靠前)
  sort_order Int @default(100)

  // 元数据
  is_default   Boolean   @default(false) // seed 默认的(允许重置)
  updated_by   String?
  updated_at   DateTime  @updatedAt @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz

  @@index([enabled, sort_order])
  @@map("red_line_rules")
}

// 老白人格档案(spec-025)
// 单行表,id='laoke',admin 可编辑(改 prompt 不会自动同步,但运营心里要知道老白是谁)
// 结构化存放 persona-laoke.md 的核心规则,让运营不用看 markdown 也能查
model LaokePersona {
  id String @id @default("laoke")

  // 身份
  identity_summary String @db.Text // "32 岁,男,自己年轻时也不擅追女生,摔过几次..."
  age              Int    @default(32)
  role             String @default("兄长型 AI") // 兄长 / 不是咨询师 / 不是导师 / 不是客服

  // 说话风格(数组存,前端列表展示 + 编辑)
  // 例:["我跟你说真的", "你想多了", "你心里其实知道答案"]
  signature_phrases String[] // 常说的话
  // 例:["我理解你的感受", "建议从以下几个方面", "宝宝/家人们"]
  forbidden_phrases String[] // 绝不说的话

  // 判断风格(自由文本 markdown)
  judgment_style String @db.Text // "敢断:'她不是在退,是有事'..."

  // 能识别什么(列表)
  recognizes String[] // ["安全行为(过度排练)", "羞耻陈述('我不配')", "灾难化思维"]

  // 话术硬约束(自由文本 markdown)
  formatting_rules String @db.Text // "单句≤15字 / 绝对不超过25字 / 给2句话也行,每句≤15字..."

  // 改 prompt 时的硬规则提醒
  // 用 markdown 写,管理员看到这个就知道改 prompt 不能怎么改
  do_not_change_warnings String? @db.Text

  // spec-026 头像(全局生效)
  avatar_url         String?   @db.Text // Supabase Storage URL,空 = 用 SVG 默认
  avatar_updated_at  DateTime? @db.Timestamptz
  avatar_updated_by  String?

  // 元数据
  updated_by String?  // admin id
  updated_at DateTime @updatedAt @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("laoke_persona")
}

// 产品迭代记录(spec-022)
// 用途:Sam / 运营回顾"我们做了什么",防止"做过什么忘了"
// 不替代 admin_audit_logs(运营操作审计) / PromptVersion / git log,
// 而是把工程 commit 浓缩成产品级中文摘要(支持 LLM 自动从 git log 生草稿)
model ProductChangelog {
  id String @id @default(cuid())

  // YYYY-MM-DD 让运营回填日期
  date String

  // feature(新功能) / improve(优化) / fix(修复) / remove(移除) / breaking(影响用户)
  category String

  // 一句话(< 50 字),如"加了积分系统"
  title String @db.VarChar(100)

  // 详情:做了什么 / 为什么 / 给谁的 — markdown
  description String? @db.Text

  // user(用户可见) / admin(运营后台) / internal(内部)
  scope String @default("user")

  // admin user id
  created_by String

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@index([date(sort: Desc)])
  @@index([category])
  @@index([scope])
  @@map("product_changelogs")
}

// 吐槽自动聚类(spec-021 P0-2)
// 每天 cron 用 Haiku 把过去 7 天 dislike+comment 分组
// 让运营 5 分钟看完一周吐槽,不用读 50 条
model FeedbackCluster {
  id String @id @default(cuid())

  // 聚类生成日期(YYYY-MM-DD,UTC+8)
  computed_for_date String

  // 主题描述(LLM 生成,中文,如"觉得老白说话太长")
  theme String @db.Text
  // 该主题下的反馈条数
  count Int
  // 该主题的代表性反馈样本(最多 5 条 PromptFeedback.id)
  sample_feedback_ids String[]

  // 这次聚类用了多少天的数据
  window_days Int @default(7)

  created_at DateTime @default(now()) @db.Timestamptz

  @@unique([computed_for_date, theme])
  @@index([computed_for_date])
  @@map("feedback_clusters")
}

model PromptFeedback {
  id              String  @id @default(cuid())
  user_id         String
  // spec-006 之后 session 退到后端复盘,日常对话流不再有 session,改 optional
  session_id      String?
  // spec-009:反馈来自哪段关系的对话流
  relationship_id String?
  message_id      String // 老 K 的某条输出(前端 message id,如 k-stream-xxx)

  // 老 K 那条回复内容快照(前端 message 可能本地变更,后端存原文用于 prompt 迭代)
  bubble_text String? @db.Text

  // 反馈类型:'like' / 'dislike' / 'comment'(spec-009 新)
  // legacy:'not_like_laoke' / 'wrong_judgment' / 'off_tone'
  feedback_type String
  feedback_note String? @db.Text

  // 当时的 prompt(用于回溯优化)
  prompt_snapshot Json?

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([feedback_type])
  @@index([user_id, created_at])
  @@index([relationship_id, feedback_type])
  @@map("prompt_feedback")
}

// ============================================================
// 用户反馈系统 — 老白关心式(M3+ FEEDBACK SPEC, 2026-05-11)
// 跟 PromptFeedback 分开:那个是消息级 like/dislike,这个是产品级使用感受
// 9 个 trigger:ACTIVATION_SCREENSHOT / ACTIVATION_DRAFT / T_D2D3 / T_D5D7
//             T_D12D14 / T_D30 / T_D60 / T_PERIODIC / CRISIS_3DISLIKE
// 详见 lianai-dev-kit-m3/06-FEEDBACK-SPEC.md
// ============================================================

model ProductFeedback {
  id              String  @id @default(cuid())
  user_id         String
  relationship_id String? // crisis 触发时所在的关系(可选)

  trigger_type    String  // 见上文 9 个 trigger 枚举
  raw_text        String  @db.Text // 用户原话,freeform
  created_at      DateTime @default(now()) @db.Timestamptz

  // LLM 异步分类(失败时为 null,admin 手动 triage)
  llm_category     String?   // PRODUCT / UI / LAOKE_PERSONA / TECH_BUG / OTHER
  llm_sentiment    String?   // POSITIVE / NEUTRAL / NEGATIVE / CRITICAL
  llm_tags         String[]  @default([]) // Haiku 提取的 2-4 个 tag
  llm_processed_at DateTime?

  // admin 处理状态
  admin_status      String   @default("NEW") // NEW / TRIAGED / OWNED / RESOLVED / DISMISSED
  admin_owner       String?
  admin_note        String?  @db.Text
  admin_resolved_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([trigger_type, created_at])
  @@index([llm_category, llm_sentiment])
  @@index([admin_status, created_at])
  @@map("product_feedback")
}

// 触发记录(防重复 + 跳过也要记,eligibility 判断查这里)
model FeedbackTriggerLog {
  id           String   @id @default(cuid())
  user_id      String
  trigger_type String
  triggered_at DateTime @default(now()) @db.Timestamptz
  responded    Boolean  @default(false) // 用户答了(true)还是跳过/关页面(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, trigger_type, triggered_at])
  @@map("feedback_trigger_log")
}

// ============================================================
// Admin 后台(spec-011)
// admin 体系跟用户端鉴权完全隔离 — 独立表/独立 JWT secret/独立 lifetime
// ============================================================

// admin 账户(M1 只 seed Sam 一条 ADMIN,M2 招人后开 RBAC)
model AdminUser {
  id String @id @default(cuid())

  email         String  @unique
  // argon2id hash,不存明文
  password_hash String  @db.Text
  // M2 强制开 TOTP 二验,M1 留 null
  totp_secret   String? @db.Text

  role   AdminRole @default(ADMIN)
  active Boolean   @default(true)

  last_login_at DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz

  audit_logs AdminAuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  ADMIN // 全权(Sam)
  SUPPORT // 客服:用户/订阅/删号
  MODERATOR // 审核:红线 + 受限用户视图
  PM // 产品:反馈 + 数据 + 受限 prompt
  ENGINEER // 工程:LLMOps + prompt + 运维
  ANALYST // 分析师:数据(脱敏)
}

// admin 操作审计 — 所有写操作 + 敏感读操作必须留痕
// (spec-011 §7.3 不变式守护)
model AdminAuditLog {
  id            String    @id @default(cuid())
  admin_user_id String
  admin_user    AdminUser @relation(fields: [admin_user_id], references: [id])

  // "view_user_detail" / "approve_refund" / "execute_deletion" / "reveal_prompt" 等
  action      String
  // "user" / "subscription" / "moderation_log" / "ai_call_log" 等
  target_type String
  target_id   String

  // 修改类操作的 before/after diff(读类操作为 null)
  before Json?
  after  Json?
  // critical 操作必填(force_delete / approve_refund 等)
  reason String? @db.Text
  ip     String?

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([admin_user_id, created_at])
  @@index([target_type, target_id])
  @@index([action, created_at])
  @@map("admin_audit_logs")
}

// AI 调用日志(spec-011 §4.2 LLMOps 基础)
// Pino transport 异步落库,不阻塞主链路
// 写量估 ~10w/天,按 created_at + scene 索引
model AiCallLog {
  id      String @id @default(cuid())
  // client.ts 生成,跟 Pino log 的 logId 对齐(便于双向追溯)
  call_id String @unique

  // 业务追溯字段(都允许 null,因为有些调用没绑定具体业务对象)
  user_id         String?
  relationship_id String?
  session_id      String?
  message_id      String?

  // "parsing" / "conversation_turn" / "ocr" / "intent_classifier" / "long_term_memory"
  scene String
  // "claude-sonnet-4-20250514" / "claude-haiku-4-5-20251001" / "gemini-2.5-flash"
  model String

  input_tokens  Int
  output_tokens Int
  // Item 2 prompt cache(2026-05-12)— 写入 cache 的 input token(1.25x 计价,第一次)
  // 老记录默认 0,新记录从 response.usage.cache_creation_input_tokens 来
  cache_creation_input_tokens Int @default(0)
  // 命中 cache 的 input token(0.10x 计价,后续读取)
  cache_read_input_tokens     Int @default(0)
  // 单次成本可能很小(~0.001 USD),用 6 位小数
  cost_usd      Decimal @db.Decimal(10, 6)
  duration_ms   Int

  // persona-check 是否通过(老 K 出格扫描)
  persona_passed Boolean
  // auditPromptContext 命中的跨关系泄漏([] = 干净 / [...] = 命中)
  leaks          Json?
  // 调用失败时的错误消息;成功时 null
  error          String? @db.Text

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([scene, created_at])
  @@index([user_id, created_at])
  @@index([persona_passed])
  @@index([created_at])
  @@map("ai_call_logs")
}

// 退款工单(spec-011 §4.5 + §6.2 路由)
// 用户提申请 → admin 审批 → 调平台 API 执行 → 关联 Payment.status
model RefundTicket {
  id         String @id @default(cuid())
  user_id    String
  payment_id String

  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("CNY")
  user_reason String  @db.Text

  status        RefundStatus @default(PENDING)
  // 审批人(AdminUser.id),状态从 APPROVED 起填
  reviewed_by   String?
  reviewed_at   DateTime?    @db.Timestamptz
  reviewer_note String?      @db.Text

  // 平台 API 执行结果(IAP / WechatPay)
  platform_executed Boolean @default(false)
  platform_response Json?

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  // Phase 1 P1.3(2026-05-14)— admin 退款列表 include payment
  payment Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@index([status, created_at])
  @@index([user_id])
  @@map("refund_tickets")
}

enum RefundStatus {
  PENDING // 用户已提申请,待审批
  APPROVED // admin 审批通过,待执行平台 API
  EXECUTING // 调平台 API 中
  DONE // 平台 API 成功,Payment 状态已 sync
  REJECTED // admin 拒绝
}

// ============================================================
// AI 质量监控(spec-013)
// PM 视角的 5 模块体系:A 调用监控(已用 AiCallLog)/ B Prompt 工程台
// / C 人工评分 / D 隐性反馈 / E Persona 监控(复用 AiCallLog)
// ============================================================

// === 模块 B:Prompt 工程台 ===

/// @deprecated M3.0 Item 1 拆除幽灵 prompt 工程台后保留(2026-05-12)
/// 应用层 0 引用(admin-prompt.service / prompt-loader / default-prompts 已删)
/// 历史数据保留,M4 决定物理 drop table
model PromptVersion {
  id             String    @id @default(cuid())
  // 'conversation_turn' / 'parsing' / 'ocr' / 'intent_classifier' 等
  name           String
  // 自增 per name
  version        Int
  content        String    @db.Text
  // admin_user_id 或 'system'(脚本灌库)
  author         String
  notes          String?   @db.Text
  // null = staging only;非空 = 当前/历史 deployed
  deployed_at    DateTime? @db.Timestamptz
  rolled_back_at DateTime? @db.Timestamptz
  // 灰度比例 0-100(deployed_at 非空才有意义,默认 100 = 全量)
  rollout_pct    Int       @default(100)

  created_at DateTime @default(now()) @db.Timestamptz

  evals PromptEval[]

  @@unique([name, version])
  @@index([name, deployed_at])
  @@map("prompt_versions")
}

/// @deprecated 同 PromptVersion(M3.0 Item 1 拆除,M4 物理 drop)
model PromptEvalDataset {
  id          String   @id @default(cuid())
  name        String   @unique
  // 适用 prompt name(可空 = 通用)
  prompt_name String?
  description String?  @db.Text
  // [{ input: {...}, expected_pattern: "...", weight: 1.0 }, ...]
  samples     Json
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  evals PromptEval[]

  @@map("prompt_eval_datasets")
}

/// @deprecated 同 PromptVersion(M3.0 Item 1 拆除,M4 物理 drop)
model PromptEval {
  id                String  @id @default(cuid())
  prompt_version_id String
  dataset_id        String
  // 'claude-sonnet-4' / 'claude-opus-4' / 'human'
  judge_model       String
  // 0-1 总分(平均 5 维)
  score             Decimal @db.Decimal(5, 4)
  // [{ sample_idx, output, persona, accuracy, helpfulness, empathy, safety, judge_note }]
  raw_results       Json
  total_samples     Int
  passed_samples    Int

  run_at DateTime @default(now()) @db.Timestamptz

  prompt_version PromptVersion     @relation(fields: [prompt_version_id], references: [id], onDelete: Cascade)
  dataset        PromptEvalDataset @relation(fields: [dataset_id], references: [id], onDelete: Cascade)

  @@index([prompt_version_id, run_at])
  @@map("prompt_evals")
}

// === 模块 C:人工评分工作台 ===

model AnnotationQueue {
  id          String @id @default(cuid())
  // 批次名:'2026-W19-weekly' / 'dislike-cluster-1' / 'manual-2026-05-08'
  batch_name  String
  // 抽样源:'random' / 'dislike' / 'persona_fail' / 'leak_hit' / 'mixed'
  source      String
  // 'pending' / 'in_review' / 'closed'
  status      String @default("pending")
  total_items Int    @default(0)

  created_at DateTime @default(now()) @db.Timestamptz

  items AnnotationItem[]

  @@index([status, created_at])
  @@map("annotation_queues")
}

model AnnotationItem {
  id          String  @id @default(cuid())
  queue_id    String
  // 关联 AiCallLog.call_id(不是 id,因为 call_id 唯一 + 业务可读)
  call_id     String
  // 评估员 admin_user_id(null = 待领取)
  reviewer_id String?

  // 5 维分数 0-1(null = 未评)
  score_persona     Decimal? @db.Decimal(3, 2)
  score_accuracy    Decimal? @db.Decimal(3, 2)
  score_helpfulness Decimal? @db.Decimal(3, 2)
  score_empathy     Decimal? @db.Decimal(3, 2)
  score_safety      Decimal? @db.Decimal(3, 2)

  // ['too_verbose', 'wrong_assumption', 'pua_smell', 'machine_tone', ...]
  tags String[]
  note String?  @db.Text

  reviewed_at              DateTime? @db.Timestamptz
  // 是否选入 eval dataset(评分员勾选)
  added_to_eval            Boolean   @default(false)
  added_to_eval_dataset_id String?

  queue AnnotationQueue @relation(fields: [queue_id], references: [id], onDelete: Cascade)

  @@index([queue_id, reviewer_id])
  @@index([call_id])
  @@map("annotation_items")
}

// === 模块 D:隐性反馈采集(用户行为埋点)===

// === 系统配置(spec-015)===
// 单行设计 — id 固定 'global',只有一行
// 改这里 = 立刻生效(后端 5 分钟缓存)
model SystemConfig {
  id String @id @default("global")

  // 免费额度(每天每用户)
  quota_turn  Int @default(20)
  quota_ocr   Int @default(5)
  quota_heavy Int @default(3)

  // 全局 bypass:true = 所有用户不限(M1 内测期默认开)
  // 上线后改 false 启用 limits;订阅用户始终 bypass(独立逻辑)
  quota_bypass_enabled Boolean @default(true)

  // spec-019 积分系统:每日免费积分上限(替代 quota_turn/ocr/heavy 三个独立上限)
  // 默认 100 = 20 句对话(5/句) 或 5 张截图(20/张) 或混合
  // 实际扣分 = POINTS_PER_ACTION (turn=5 / ocr=20 / heavy=30,定义在 quota.service)
  daily_free_points Int @default(100)

  // Phase 1 P1.2(2026-05-14)— quota bypass 的 chat_type 列表
  // 命中此列表的 chat_type 直接 bypass(零成本),用于树洞免费引流
  // 跟 PointsPricing 表的 (action, chat_type) → cost=0 双保险(quota 优先级最高)
  quota_bypass_chat_types String[] @default(["TREE_HOLE"])

  // Anthropic 账户余额基准(spec-billing v1):
  // Anthropic 不提供"剩余余额"API,只有 cost_report 累计花费。
  // 所以让 admin 手动填"某时点的余额快照",运行时算 baseline - 自此累计花费 = 估算余额。
  // baseline_at 为 null = 还没初始化过,前端提示"先去填基准"
  anthropic_credit_baseline_usd Decimal?  @db.Decimal(10, 2)
  anthropic_credit_baseline_at  DateTime? @db.Timestamptz
  anthropic_credit_updated_by   String?
  anthropic_credit_updated_at   DateTime? @db.Timestamptz

  // spec-m2-000 任务 5 (2026-05-12):数据生产端开关 + 节奏配置
  // 让运营在 admin 后台调"老白每轮抽不抽 observation"/"用户多少条触发 fingerprint"
  observation_extractor_enabled   Boolean @default(true)
  fingerprint_extractor_enabled   Boolean @default(true)
  fingerprint_extraction_interval Int     @default(20) // 每 N 条 user 消息触发一次

  // spec-m2-003 任务 1 (2026-05-12):长期记忆门槛参数化(默认从 100 降到 30)
  long_term_memory_threshold     Int @default(30) // 对话超过 N 条才启动摘要
  long_term_memory_window_size   Int @default(80) // 最近 N 条原文进 prompt,更早的压缩

  // spec-m2-004 任务 1 (2026-05-12):数据流开关 + 可调参数
  // 让运营在 admin 后台控制"老白每次回复时看到什么数据"
  enable_profile_assertions       Boolean @default(true) // 关掉 → 老白看不到她的稳定特征
  enable_relationship_observations Boolean @default(true) // 关掉 → 老白记不住自己以前怎么想
  enable_user_language_fingerprint Boolean @default(true) // 关掉 → 话术可能不像兄弟会说的
  enable_long_term_memory          Boolean @default(true) // 关掉 → 对话超 30 条后早期细节丢失
  enable_emotion_recognition       Boolean @default(true) // 关掉 → 老白只看历史不看当下(M2 暂未独立开关化,留接口)

  history_window_size              Int @default(80) // 老白每次看最近多少条对话(30-200)
  profile_assertions_limit         Int @default(20) // 取最高 priority 的多少条 assertion(5-50)
  observations_limit               Int @default(30) // 取最近多少条 observation(10-100)

  // 2026-05-12:用户默认头像(没头像的用户 fallback 到这个 URL)
  // 上传到 supabase 的 lianai-avatars/_default/ 路径,admin 可改可删
  user_default_avatar_url          String? @db.Text

  // 2026-05-13:用户可选预设头像列表(注册 / 编辑时给用户挑的那 N 张)
  // 空数组 → mobile fallback 到 hardcode 的 DiceBear 8 张;非空 → 走 admin 配的这组
  // 上传到 supabase 的 lianai-avatars/_preset/ 路径
  user_preset_avatar_urls          String[] @default([])

  updated_by String?
  updated_at DateTime @updatedAt @db.Timestamptz

  @@map("system_config")
}

// spec-m2-003 任务 2 (2026-05-12):长期记忆缓存
// 替代 M1 每轮重算 Haiku 的应急方案。
// 缓存 key = relationship_id(每段关系一份摘要)
// covered_until_count = 缓存生成时 history.length(用于判断是否需增量更新)
// M3.0 Item 12 Module 4(2026-05-12)— Persona Auto-Suggestion
// 周分析 auto_lint + failure case → 生成 LaokePersona 字段更新建议
// 经 constitution-check 5 铁律预审通过 → 写入此表 admin 审核队列
// admin 接受 → 应用到 LaokePersona;拒绝 → 标 rejected;待审 → pending
model PersonaSuggestion {
  id              String   @id @default(cuid())

  // 'add_signature_phrase' / 'add_forbidden_phrase' / 'modify_judgment_style' / ...
  field           String
  // 'add' / 'modify' / 'remove'
  action          String
  // 建议内容(JSON,根据 field/action 不同结构不同)
  content         String   @db.Text
  // LLM 给的理由
  reason          String   @db.Text

  // 数据出处(Module 4 分析的来源)
  source_window_days   Int     @default(7)
  source_auto_lint_ids String[] @default([])
  source_failure_ids   String[] @default([])

  // 'pending' / 'approved' / 'rejected' / 'auto_applied'
  status          String   @default("pending")
  reviewed_by     String? // admin user id
  review_note     String?  @db.Text
  reviewed_at     DateTime? @db.Timestamptz

  // 老白宪法 5 铁律预审结果(JSON: { passed: boolean, violations: [...] })
  constitution_check Json?

  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  @@index([status, created_at])
  @@map("persona_suggestions")
}

// M3.0 Item 10(2026-05-12)— 时序里程碑,M3.2 D2 季度档案的替代设计
// 每 7 天异步跑"本周里程碑提取",老白把当周对话提炼成 0-3 个里程碑事件
// 用途:admin 看时间线 + 用户"我的关系故事"页
// 数据周期:用户用 ≥7 天才有第一批,代码层先 ship,功能跟着数据自然显化
model RelationshipMilestone {
  id              String @id @default(cuid())
  relationship_id String

  // 'breakthrough' | 'setback' | 'turn_warm' | 'turn_cold' | 'first_x' | 'pattern'
  // 由 LLM 抽取时分类,admin 可手动改
  milestone_type  String

  // 简短标题(20 字内)
  title           String
  // 详细描述(老白口吻 markdown,200 字内)
  description     String  @db.Text

  // 时间范围:这个里程碑发生在哪几天
  occurred_at     DateTime @db.Timestamptz
  // 数据出处 message id(2-5 条相关消息)
  source_message_ids String[] @default([])

  // 用户可编辑(改标题 / 描述 / 隐藏)
  user_edited     Boolean   @default(false)
  hidden_by_user  Boolean   @default(false)
  user_note       String?   @db.Text

  // 提取来源
  // 'auto_weekly' = 每周 cron 自动提取(默认)
  // 'manual'      = admin 或用户手动加
  source_type     String    @default("auto_weekly")

  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  @@index([relationship_id, occurred_at])
  @@index([relationship_id, hidden_by_user])
  @@map("relationship_milestones")
}

// M3.0 Item 6(2026-05-12)— 案例库,Module 2 数据沉淀
// 用户 like + admin ≥4 分 → type='success',反 → type='failure'
// 为 Item 9 Dynamic Few-Shot 准备数据;Item 8 加 embedding 字段(M3.2 7 月)
//
// 设计:单表 + type 字段(比双表 SuccessCase/FailureCase 简洁;查询更灵活)
model LearningCase {
  id              String   @id @default(cuid())

  // 'success' | 'failure'
  type            String

  // 来源
  source_type     String   // 'user_feedback' / 'admin_score' / 'manual'
  source_id       String?  // PromptFeedback.id / annotation id

  user_id         String
  relationship_id String?
  message_id      String   // 老白消息 ID(Message.id)

  // 上下文(给 Module 3 few-shot 用)
  user_text       String   @db.Text  // 用户当时说啥
  laoke_text      String   @db.Text  // 老白怎么回的
  scene           String   // conversation_turn / ocr / ...

  // 评分 0-5(success: ≥4, failure: ≤2)
  score           Float    @default(0)
  score_reason    String?  @db.Text

  created_at      DateTime @default(now()) @db.Timestamptz

  @@unique([type, source_id])
  @@index([type, scene, created_at])
  @@index([relationship_id, created_at])
  @@map("learning_cases")
}

model LongTermMemoryCache {
  id                    String @id @default(cuid())
  relationship_id       String @unique

  // 摘要内容(200-400 字老白口吻 markdown)
  summary               String @db.Text

  // 缓存覆盖范围:生成时 history.length 是多少
  // 下次调用比较当前 history.length:相等→用缓存 大于→增量摘要 小于→全量重算
  covered_until_count   Int

  // M3.0 Item 3(2026-05-12)— 摘要生成基于哪些 assertions
  // admin/dispute 删除 assertion 时反查此字段删 cache,防止 cache 含已删除的画像信息
  source_assertion_ids  String[] @default([])

  // 元数据
  model_version         String   @default("haiku-4.5")
  generated_at          DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @updatedAt @db.Timestamptz

  @@index([relationship_id])
  @@map("long_term_memory_cache")
}

// === 用户颗粒度管理(spec-014)===
// 用户标签 — admin 内部用,用户不可见
// 自动标签:每天凌晨 cron 重新计算(sleeping / high_activity / red_line_hit 等)
// 手动标签:运营自己打(种子用户 / 创始人朋友 / 已邀请测试群 等)
model UserTag {
  id         String    @id @default(cuid())
  user_id    String
  // 'system' = cron 自动打;'manual' = 运营手动打
  source     String
  // 标签名:系统标签限定 7 个(newbie / sleeping / high_activity / high_feedback
  // / red_line_hit / paying / high_cost);手动标签任意字符串(中文 OK)
  tag        String
  // 自动标签:cron 下次跑会重算;手动标签 null = 永久
  expires_at DateTime? @db.Timestamptz
  // 系统标签自动打时的依据(冗余存,debug 用):"近 7 天 0 次对话" 等
  reason     String?   @db.Text
  // 手动标签:打标签的 admin_user_id;自动标签 'system'
  added_by   String

  created_at DateTime @default(now()) @db.Timestamptz

  @@unique([user_id, tag])
  @@index([tag])
  @@index([user_id])
  @@map("user_tags")
}

// 用户备注 — admin 内部用,**用户不可见**
// 一个用户可以有多条备注(客服互动记录、运营标记等),按时间倒序展示
model UserNote {
  id       String @id @default(cuid())
  user_id  String
  // 写备注的 admin_user_id(可追溯责任人)
  admin_id String
  content  String @db.Text

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@index([user_id, created_at])
  @@map("user_notes")
}

model BehaviorEvent {
  id              String  @id @default(cuid())
  user_id         String
  relationship_id String?
  // 老 K 那条 message id(前端 streaming id 或 Anthropic msg_xxx)
  message_id      String?

  // 'laoke_reply_received' / 'user_idle_30s' / 'user_left_app' /
  // 'user_typed_after_laoke' / 'user_copied_draft' / 'user_sent_after_draft'
  event_type String

  // 老 K 那条 message 的发送时间(算 latency 用,可空)
  reference_at DateTime? @db.Timestamptz

  // 任意 metadata(消息长度 / 输入字符数 / 离开时背景时长等)
  metadata Json?

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([user_id, event_type, created_at])
  @@index([message_id])
  @@index([event_type, created_at])
  @@map("behavior_events")
}

// 客户端错误日志(2026-05-10)
//
// mobile 端 client.ts 在请求失败 / 超时 / 网络错误时上报到 /v1/client-errors。
// 用于 admin /errors 实时错误流,看真实用户哪些 path / code 在出错,定向治理。
//
// 隐私:不存任何用户输入文本,只 path + code + 简短 message + ua 摘要。
// user_id 可空(报错时可能没 token / token 失效)。
model ClientErrorLog {
  id String @id @default(cuid())

  user_id String?

  path    String  @db.VarChar(500)
  method  String  @db.VarChar(10)
  code    String  @db.VarChar(50)
  message String  @db.VarChar(500)
  detail  String? @db.VarChar(2000)

  // 客户端环境信息
  ua  String? @db.VarChar(500)
  url String? @db.VarChar(500)
  ip  String? @db.VarChar(64)

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([code, created_at])
  @@index([path, created_at])
  @@index([created_at])
  @@map("client_error_logs")
}

// ============================================================
// Phase 1 P1.1(2026-05-14)— 新场景数据骨架
// 见 lianai-phase1-spec-v2/01-SPEC-P1.1-DATA-SKELETON.md
//
// 4 类对话/工具场景的数据基础:
//   - TreeHoleSession + TreeHoleMessage 老白树洞
//   - InterpretSession + InterpretMessage 解读神器
//   - ArchiveReport 她档案完整版(Phase 2 写实际生成逻辑)
//   - DeepReport 深度复盘(Phase 2 写实际生成逻辑)
// ============================================================

// 树洞 session — 跨自然日(Asia/Shanghai)新建
model TreeHoleSession {
  id      String @id @default(cuid())
  user_id String

  // 跨自然日新建,基于 Asia/Shanghai 时区
  date DateTime @db.Date

  started_at DateTime  @default(now()) @db.Timestamptz
  ended_at   DateTime? @db.Timestamptz

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user     User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages TreeHoleMessage[]

  @@unique([user_id, date])
  @@index([user_id, date])
  @@map("tree_hole_sessions")
}

// 树洞 message — 不关联主 Message 表(树洞业务独立)
model TreeHoleMessage {
  id                   String @id @default(cuid())
  tree_hole_session_id String
  user_id              String // 冗余便于查询

  role    TreeHoleMessageRole
  content String              @db.Text

  // Phase 2 才填:类型识别异步写入
  mentioned_person Json?
  mentioned_type   Json?

  // Phase 2 才用:桥接到 relationship
  linked_relationship_id String?

  created_at DateTime @default(now()) @db.Timestamptz

  tree_hole_session TreeHoleSession @relation(fields: [tree_hole_session_id], references: [id], onDelete: Cascade)

  @@index([tree_hole_session_id, created_at])
  @@index([user_id, created_at])
  @@map("tree_hole_messages")
}

// 解读 session — 30 分钟过期
model InterpretSession {
  id      String @id @default(cuid())
  user_id String

  relationship_id String?

  expires_at DateTime @db.Timestamptz

  created_at DateTime @default(now()) @db.Timestamptz

  user         User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  relationship Relationship?      @relation(fields: [relationship_id], references: [id])
  messages     InterpretMessage[]

  @@index([user_id, created_at])
  @@map("interpret_sessions")
}

// 解读 message — JSON 输入 + JSON 输出
model InterpretMessage {
  id                   String @id @default(cuid())
  interpret_session_id String

  // { her_text, context_optional, screenshot_url_optional }
  user_input Json
  // { suggested_reply, why_brief, detected_intent, alternative_replies[] }
  output_interpretation Json

  points_cost Int @default(0) // P1.2 接入后填真值

  created_at DateTime @default(now()) @db.Timestamptz

  interpret_session InterpretSession @relation(fields: [interpret_session_id], references: [id], onDelete: Cascade)

  @@index([interpret_session_id, created_at])
  @@map("interpret_messages")
}

// 她档案完整版 — Phase 1 只建表骨架,生成逻辑 Phase 2
model ArchiveReport {
  id              String @id @default(cuid())
  user_id         String
  relationship_id String

  content     String @db.Text // Phase 2 写入实际内容
  points_cost Int    @default(0)

  generated_at DateTime @default(now()) @db.Timestamptz

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)

  @@index([user_id, generated_at])
  @@index([relationship_id])
  @@map("archive_reports")
}

// 深度复盘 — Phase 1 只建表骨架,生成逻辑 Phase 2
model DeepReport {
  id              String @id @default(cuid())
  user_id         String
  relationship_id String

  content     String @db.Text
  points_cost Int    @default(0)

  generated_at DateTime @default(now()) @db.Timestamptz

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)

  @@index([user_id, generated_at])
  @@index([relationship_id])
  @@map("deep_reports")
}

// ============================================================
// Phase 1 P1.2(2026-05-14)— 三层余额(基于 spec-019 增量)
// 见 lianai-phase1-spec-v2/02-SPEC-P1.2-CREDIT-LAYERS.md
//
// 三层余额优先级:
//   1. quota_bypass_chat_types 命中(TREE_HOLE)→ chat_type_bypass
//   2. SystemConfig.quota_bypass_enabled=true(M1 默认)→ bypass
//   3. Subscription.status='ACTIVE' → subscribed
//   4. UserTag 'temp_unlimited' → bypass
//   5. DailyUsage.points_used + cost ≤ daily_free_points(免费层)→ 扣 daily
//   6. User.purchased_points ≥ cost(购买层)→ paid_from_purchased
//   7. 都不够 → insufficient_balance
// ============================================================

// 积分流水
model CreditTransaction {
  id      String @id @default(cuid())
  user_id String

  type CreditTxType

  amount        Int // 正=加 / 负=扣
  balance_after Int // 操作后的 purchased_points

  // 关联(可选)
  payment_id       String?
  source_action    String? // 'turn' / 'ocr' / 'heavy'
  source_chat_type String? // ChatType 值

  note String? @db.Text

  created_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([type, created_at])
  @@map("credit_transactions")
}

enum CreditTxType {
  PURCHASE // 购买
  CONSUME // 消耗(走 paid_from_purchased 路径时)
  GRANT // 系统赠送(反向试用 Phase 2)
  REFUND // 退款扣回(P1.3)
}

// 积分消耗规则(chat_type 差异化覆盖,默认沿用 POINTS_PER_ACTION)
// action_kind / chat_type 用 String 不用 enum,避免类型耦合 + 允许 null = 通用
model PointsPricing {
  id String @id @default(cuid())

  action_kind String // 'turn' / 'ocr' / 'heavy'
  chat_type   String? // ChatType 值 / null = 通用 fallback

  points_cost Int
  enabled     Boolean @default(true)

  admin_note String? @db.Text

  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  updated_by String?

  @@unique([action_kind, chat_type])
  @@map("points_pricing")
}

// ============================================================
// Phase 1 P1.3(2026-05-14)— 商品定价 DB 化
// ============================================================
// admin 可调价格 / 上下架 / 改文案,seed 4 个商品(年费 + 30/100/300 积分包)
model BillingProduct {
  id           String      @id @default(cuid())
  product_type ProductType @unique

  name        String
  description String  @db.Text

  // 元,Decimal(10,2)
  price          Decimal  @db.Decimal(10, 2)
  // 原价(划线显示用)
  original_price Decimal? @db.Decimal(10, 2)

  // 积分包大小(SUBSCRIPTION_YEARLY = null)
  credit_pack_size Int?
  // 订阅天数(CREDIT_PACK_* = null)
  duration_days    Int?

  enabled    Boolean @default(true)
  sort_order Int     @default(100)

  admin_note String? @db.Text

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String?

  @@map("billing_products")
}

enum ProductType {
  SUBSCRIPTION_YEARLY
  CREDIT_PACK_30
  CREDIT_PACK_100
  CREDIT_PACK_300
}
