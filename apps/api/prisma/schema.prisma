// 练爱 - 数据库 Schema (Prisma)
// 
// 用法:
// 1. 把这份文件复制到 apps/api/prisma/schema.prisma
// 2. 创建 PostgreSQL 数据库,启用 pgvector 扩展
// 3. 配置 DATABASE_URL 环境变量
// 4. 跑 `pnpm prisma migrate dev --name init`
//
// 重要约束(见 CLAUDE.md):
// - 所有涉及关系数据的表都有 relationship_id (除 users 自己)
// - 软删除字段 deleted_at,30 天后由 worker 真删
// - 所有时间字段用 timestamptz
// - 所有 ID 用 cuid 或 uuid

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// 用户相关
// ============================================================

model User {
  id              String    @id @default(cuid())
  
  // 微信登录信息
  wechat_open_id  String    @unique
  wechat_union_id String?   @unique
  
  // 用户填写信息
  nickname        String?
  avatar_url      String?
  gender          Gender?
  birth_year      Int?
  city            String?
  
  // 产品状态
  usage_stage     UsageStage @default(NEWBIE)
  total_sessions  Int        @default(0)
  
  // 用户语气指纹(JSON 存储)
  // 详见 user-language-fingerprint 表
  
  // 时间
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  
  // 关系
  relationships         Relationship[]
  sessions              Session[]
  language_fingerprint  UserLanguageFingerprint?
  patterns              UserPattern[]
  growth_reports        GrowthReport[]
  subscriptions         Subscription[]
  payments              Payment[]
  data_deletions        DataDeletionLog[]
  
  @@map("users")
  @@index([deleted_at])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// 使用阶段:决定 AI 介入程度
enum UsageStage {
  NEWBIE       // 新手:前 30 天/30 次
  FAMILIAR     // 熟悉:30-90 天/30-90 次
  ADVANCED     // 进阶:90 天+
}

// 用户语气指纹(独立表方便累积更新)
model UserLanguageFingerprint {
  id                String  @id @default(cuid())
  user_id           String  @unique
  
  // 用户的字词偏好(JSON 数组)
  // 例: ["哈哈", "嗯", "好的", "哎呀"]
  preferred_phrases String[]
  
  // 标点习惯
  uses_emoji        Boolean @default(false)
  uses_period       Boolean @default(true)  // 是否爱用句号
  message_length    String  @default("medium") // short / medium / long
  
  // 语气强度 0-100
  formality         Int     @default(50)    // 越高越正式
  emotionality      Int     @default(50)    // 越高越情绪化
  
  // 累积样本数
  sample_count      Int     @default(0)
  
  // 实际样本(用于 few-shot)
  // 存最近 30 条用户的真实输出
  recent_samples    Json    @default("[]")
  
  updated_at        DateTime @updatedAt @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("user_language_fingerprints")
}

// 用户行为模式(由 Pattern Detector 异步生成)
model UserPattern {
  id              String   @id @default(cuid())
  user_id         String
  
  pattern_type    String   // 例: "灾难化思维" / "安全行为" / "羞耻陈述"
  description     String   // 具体描述
  
  // 出处:这个模式从哪几个 session 提取的
  source_sessions String[] // session_id 数组
  
  occurrences     Int      @default(1)
  first_seen_at   DateTime @db.Timestamptz
  last_seen_at    DateTime @db.Timestamptz
  
  // 用户是否已经看到这条模式(在月度报告中)
  surfaced        Boolean  @default(false)
  
  created_at      DateTime @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("user_patterns")
  @@index([user_id, deleted_at])
}

// ============================================================
// 关系相关
// ============================================================

model Relationship {
  id              String   @id @default(cuid())
  user_id         String
  
  // 用户给这段关系起的名字
  name            String   // 例: "小雨"
  
  // 头像(渐变色 hash 或上传 URL)
  avatar_seed     String?
  avatar_url      String?
  
  // 关系阶段(用户填,产品识别)
  stage           RelationshipStage @default(INIT)
  
  // 用户填写的基础事实(JSON)
  // 例: { how_met: "朋友介绍", first_met_at: "2024-03", key_facts: ["喜欢爵士乐"] }
  basic_facts     Json     @default("{}")
  
  // 用户提醒老 K 的注意事项(JSON 数组)
  user_reminders  Json     @default("[]")
  
  // 是否归档
  archived        Boolean  @default(false)
  
  // 时间
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  
  // 关系
  user            User                       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sessions        Session[]
  observations    RelationshipObservation[]
  assertions      ProfileAssertion[]
  
  @@map("relationships")
  @@index([user_id, archived, deleted_at])
}

enum RelationshipStage {
  INIT          // 初识
  FLIRTING      // 暧昧
  COMMITTED     // 在一起
  CONFLICT      // 冲突中
  RECOVERY      // 挽回中
  ENDED         // 已结束
}

// 关系观察:每条带 source 追溯
// 这是数据壁垒的核心
model RelationshipObservation {
  id                  String   @id @default(cuid())
  relationship_id     String   // ★ 强制约束
  
  observation_text    String   @db.Text
  
  // 出处
  source_session_id   String?
  source_message_ids  String[] // message_id 数组
  
  // 类型:对方的事实 / 用户的反思 / 关系动态等
  observation_type    String
  
  // 置信度 0-1 (Profile Updater 提取时的置信度)
  confidence          Float    @default(0.5)
  
  // 是否被用户标记"这条不准"
  user_disputed       Boolean  @default(false)
  user_dispute_note   String?
  
  // 是否提升到 profile_assertions
  promoted            Boolean  @default(false)
  
  // 向量化(M2 启用)
  // embedding         Unsupported("vector(1536)")?
  
  created_at          DateTime @default(now()) @db.Timestamptz
  deleted_at          DateTime? @db.Timestamptz
  
  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)
  
  @@map("relationship_observations")
  @@index([relationship_id, deleted_at])
  @@index([source_session_id])
}

// 高频核心断言:从多次 observation 凝练出来
// Prompt 组装时优先注入这一层
model ProfileAssertion {
  id                String   @id @default(cuid())
  relationship_id   String   // ★ 强制约束
  
  assertion_text    String   @db.Text  // 例: "她不喜欢被催"
  
  // 这个断言基于哪几个 observation
  source_observation_ids String[]
  
  // 置信度(由多个 observation 累积)
  confidence        Float
  
  // 用户是否标记不准
  user_disputed     Boolean  @default(false)
  
  // 优先级(决定 prompt 中的顺序)
  priority          Int      @default(50)
  
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz
  
  relationship Relationship @relation(fields: [relationship_id], references: [id], onDelete: Cascade)
  
  @@map("profile_assertions")
  @@index([relationship_id, deleted_at, priority])
}

// ============================================================
// 复盘会话相关
// ============================================================

model Session {
  id                String   @id @default(cuid())
  user_id           String
  relationship_id   String   // ★ 强制约束
  
  // 状态机当前状态
  state             SessionState @default(ENTRY)
  
  // 场景识别结果(JSON)
  // 例: { primary: "FLIRT_008", secondary: ["FLIRT_005"], confidence: 0.85 }
  scenario          Json?
  
  // 用户在 ENTRY 阶段填的简单描述
  entry_note        String?
  
  // 状态机的 context(完整快照)
  // 用 XState 的 state.context 序列化
  state_context     Json     @default("{}")
  
  // 是否触发危机干预
  crisis_triggered  Boolean  @default(false)
  
  // 是否触发红线(不进入用户成长档案)
  red_line_triggered Boolean @default(false)
  
  // 时间
  started_at        DateTime @default(now()) @db.Timestamptz
  closed_at         DateTime? @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz
  
  // 关系
  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  relationship      Relationship      @relation(fields: [relationship_id], references: [id], onDelete: Cascade)
  messages          Message[]
  reflections       UserReflection[]
  generated_replies GeneratedReply[]
  
  @@map("sessions")
  @@index([user_id, closed_at])
  @@index([relationship_id, closed_at])
}

enum SessionState {
  ENTRY
  PARSING
  REFLECTING
  DIAGNOSING
  PLANNING
  DRAFTING
  CLOSED
}

// 消息(对话内容)
model Message {
  id              String   @id @default(cuid())
  session_id      String
  relationship_id String   // ★ 冗余存储,方便审计和过滤
  
  // 角色
  role            MessageRole
  
  // 内容(用户消息可能是文本或截图)
  content         String?  @db.Text
  
  // 截图相关(role = USER_SCREENSHOT 时使用)
  screenshot_url  String?
  ocr_result      Json?    // OCR 识别后的结构化数据
  
  // AI 调用相关(role = LAOKE 时使用)
  model           String?  // "claude-sonnet-4" / "gemini-2.5-flash"
  prompt_tokens   Int?
  completion_tokens Int?
  cost_usd        Float?
  
  // 是否是流式输出(还在生成中?)
  is_streaming    Boolean  @default(false)
  
  // 时间
  created_at      DateTime @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  
  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  
  @@map("messages")
  @@index([session_id, created_at])
  @@index([relationship_id])
}

enum MessageRole {
  USER             // 用户文字输入
  USER_SCREENSHOT  // 用户上传截图
  LAOKE            // 老 K 输出
  SYSTEM           // 系统消息(状态切换提示等)
}

// 用户在 REFLECTING 阶段的回答
model UserReflection {
  id              String   @id @default(cuid())
  session_id      String
  
  question        String   // 老 K 问的问题
  question_index  Int      // 第几个问题(1-3)
  
  user_answer     String   @db.Text
  
  // 是否被老 K 追问过
  follow_up       Boolean  @default(false)
  
  created_at      DateTime @default(now()) @db.Timestamptz
  
  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  
  @@map("user_reflections")
  @@index([session_id])
}

// 生成的话术卡片(DRAFTING 状态输出)
model GeneratedReply {
  id              String   @id @default(cuid())
  session_id      String
  
  // 第几张卡片(0/1/2)
  card_index      Int
  
  // 卡片方向标签(例: "轻巧化解" / "换话题" / "温柔回应")
  direction_label String
  
  // 话术内容
  reply_text      String   @db.Text
  
  // 三个解释
  what_it_does    String   // 做了什么
  good_for        String   // 适合什么
  trade_off       String   // 代价是什么
  
  // 用户是否选了这张卡
  user_selected   Boolean  @default(false)
  
  // 用户是否调过(自然语言追问打磨)
  user_refined    Boolean  @default(false)
  refined_text    String?  @db.Text
  
  // 用户是否复制了
  user_copied     Boolean  @default(false)
  
  created_at      DateTime @default(now()) @db.Timestamptz
  
  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  
  @@map("generated_replies")
  @@index([session_id])
}

// ============================================================
// 成长报告
// ============================================================

model GrowthReport {
  id              String   @id @default(cuid())
  user_id         String
  
  // 报告类型和时间范围
  report_type     ReportType
  period_start    DateTime @db.Date
  period_end      DateTime @db.Date
  
  // 数据统计
  total_sessions  Int
  total_relationships Int
  
  // AI 生成的内容
  // 例: { "三件事": [...], "关键瞬间": [...], "下个月建议": "..." }
  content         Json
  
  // 用户是否查看过
  read_at         DateTime? @db.Timestamptz
  
  created_at      DateTime @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("growth_reports")
  @@index([user_id, period_end])
}

enum ReportType {
  MONTHLY
  QUARTERLY  // M2
  YEARLY     // M3
}

// ============================================================
// 付费相关
// ============================================================

model Subscription {
  id                String   @id @default(cuid())
  user_id           String
  
  plan              SubscriptionPlan
  status            SubscriptionStatus
  
  // 起止时间
  started_at        DateTime @db.Timestamptz
  expires_at        DateTime @db.Timestamptz
  
  // 平台和支付信息
  platform          PaymentPlatform
  apple_transaction_id   String? @unique
  apple_original_transaction_id String?
  wechat_transaction_id  String? @unique
  
  // 自动续费
  auto_renew        Boolean  @default(true)
  
  // 取消信息
  canceled_at       DateTime? @db.Timestamptz
  cancel_reason     String?
  
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
  @@index([user_id, status])
}

enum SubscriptionPlan {
  SINGLE   // 单次 ¥6.6
  MONTHLY  // 月付 ¥39
  YEARLY   // 年付 ¥299
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  REFUNDED
  PENDING_REFUND
}

enum PaymentPlatform {
  APPLE_IAP
  WECHAT_PAY
}

// 单笔支付记录
model Payment {
  id                String   @id @default(cuid())
  user_id           String
  subscription_id   String?
  
  amount            Decimal  @db.Decimal(10, 2) // 金额(元)
  currency          String   @default("CNY")
  
  platform          PaymentPlatform
  
  // 平台 transaction id
  platform_transaction_id String? @unique
  
  status            PaymentStatus
  
  // 退款相关
  refunded_at       DateTime? @db.Timestamptz
  refund_amount     Decimal?  @db.Decimal(10, 2)
  refund_reason     String?
  
  // 原始 webhook 数据(用于审计)
  raw_data          Json?
  
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("payments")
  @@index([user_id])
  @@index([platform_transaction_id])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUNDED
}

// ============================================================
// 数据控制权
// ============================================================

model DataDeletionLog {
  id                String   @id @default(cuid())
  user_id           String
  
  type              DeletionType
  target_id         String?  // relationship_id / session_id / observation_id
  
  // 30 天反悔窗口
  requested_at      DateTime @default(now()) @db.Timestamptz
  execute_at        DateTime @db.Timestamptz
  executed          Boolean  @default(false)
  executed_at       DateTime? @db.Timestamptz
  
  // 用户撤销(在 execute_at 前)
  canceled_at       DateTime? @db.Timestamptz
  cancel_reason     String?
  
  created_at        DateTime @default(now()) @db.Timestamptz
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@map("data_deletion_logs")
  @@index([execute_at, executed])
}

enum DeletionType {
  ACCOUNT_DELETE       // 注销账号
  RELATIONSHIP_DELETE  // 删除整段关系
  SESSION_DELETE       // 删除单次复盘
  OBSERVATION_DELETE   // 删除单条观察
}

// ============================================================
// 内容审核日志
// ============================================================

model ModerationLog {
  id              String   @id @default(cuid())
  
  // 触发的来源
  source_type     String   // "user_input" / "ai_output"
  source_id       String?  // message_id 等
  user_id         String?
  
  // 内容
  content         String   @db.Text
  
  // 审核结果
  service         String   // "aliyun_content_security" / "internal_red_line"
  passed          Boolean
  category        String?  // "porn" / "politics" / "violence" / "self_harm" 等
  confidence      Float?
  raw_response    Json?
  
  created_at      DateTime @default(now()) @db.Timestamptz
  
  @@map("moderation_logs")
  @@index([user_id, created_at])
  @@index([passed, category])
}

// ============================================================
// Prompt 评估反馈(用于持续优化)
// ============================================================

model PromptFeedback {
  id              String   @id @default(cuid())
  user_id         String
  session_id      String
  message_id      String   // 老 K 的某条输出
  
  // 反馈类型
  feedback_type   String   // "not_like_laoke" / "wrong_judgment" / "off_tone" 等
  feedback_note   String?  @db.Text
  
  // 当时的 prompt(用于回溯优化)
  prompt_snapshot Json?
  
  created_at      DateTime @default(now()) @db.Timestamptz
  
  @@map("prompt_feedback")
  @@index([feedback_type])
}
