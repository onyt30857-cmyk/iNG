# 练爱后端环境变量示例
# 用法: cp .env.example .env, 然后填好下面的值

# === 基础 ===
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# === 数据库 ===
# 用 docker-compose.yml 里的 lianai-postgres 容器
DATABASE_URL=postgresql://lianai:lianai@localhost:5432/lianai

# === Redis ===
REDIS_URL=redis://localhost:6379

# === 鉴权 ===
# 生产环境必须用强随机字符串(openssl rand -base64 32)
JWT_SECRET=replace-me-with-strong-random-string-at-least-32-chars
JWT_EXPIRES_IN=30d

# === Admin 后台鉴权(spec-011)===
# 必须跟 JWT_SECRET 不同(代码会校验),用独立强随机
# 生成: openssl rand -base64 48
ADMIN_JWT_SECRET=replace-me-different-from-jwt-secret-at-least-32-chars
ADMIN_ACCESS_TTL=15m
ADMIN_REFRESH_TTL=7d

# === AI 模型 ===
# Anthropic Claude (主对话)
# 注意: 模型 ID 在实施时确认 Anthropic 当前最新 ID
ANTHROPIC_API_KEY=
CLAUDE_MODEL_ID=claude-sonnet-4-20250514

# Google Gemini (OCR + 意图分类)
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# === Supabase Storage(头像 / 截图 OSS,Sam 选 Supabase 替代阿里云)===
# 没填会 graceful degrade 到 base64 data URL(M1 dev 行为,生产必须填)
# 创建步骤见 lianai-dev-kit/06-deployment/SUPABASE_SETUP.md
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_AVATAR_BUCKET=lianai-avatars

# === 阿里云(已弃用,保留兼容)===
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=lianai-dev
ALIYUN_CONTENT_MODERATION_ENDPOINT=https://green-cip.cn-shanghai.aliyuncs.com

# === 微信 ===
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# === 监控 ===
# 开发环境留空,生产环境必填
SENTRY_DSN=

# === CORS ===
# 开发用 *, 生产填具体域名
CORS_ORIGIN=*
